{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://notary.example/schema/agent-receipt/v0.1.json",
  "title": "Agent Receipt",
  "description": "Tamper-evident, receiver-attested receipt for a cross-organization agent action. v0.1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "prior_receipt_id",
    "action_canonical_hash",
    "sender_identity",
    "receiver_identity",
    "timestamp",
    "signature",
    "signature_algorithm"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID. Crockford base32, 26 chars."
    },
    "prior_receipt_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" }
      ],
      "description": "ULID of the immediate predecessor, or null at chain root."
    },
    "action_canonical_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "SHA-256 over the RFC 8785 JCS form of the underlying business action object."
    },
    "sender_identity": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque identifier (typically a DID) for the signer."
    },
    "receiver_identity": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque identifier for the addressed counterparty."
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "description": "RFC 3339 UTC timestamp with trailing Z."
    },
    "signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]{86}==$",
      "description": "Base64 of the 64-byte ed25519 signature."
    },
    "signature_algorithm": {
      "type": "string",
      "enum": ["ed25519"]
    }
  }
}
